# ── LLM Providers (at least one required) ───────────────────
GROQ_API_KEY=           # console.groq.com — free, no credit card
GEMINI_API_KEY=         # aistudio.google.com
CEREBRAS_API_KEY=       # inference.cerebras.ai — 1M tokens/day free
OLLAMA_BASE_URL=        # http://localhost:11434 — optional, local only
OLLAMA_MODEL=qwen2.5-coder:7b

# ── Model Routing ────────────────────────────────────────────
MODEL_BACKEND=auto      # auto | groq | gemini | cerebras | ollama

# ── Remote Linux / Docker over SSH ──────────────────────────
SSH_HOST=
SSH_USERNAME=
SSH_PASSWORD=
SSH_PORT=22

# ── AWS ──────────────────────────────────────────────────────
AWS_DEFAULT_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── GitHub Actions ───────────────────────────────────────────
GITHUB_TOKEN=           # Personal Access Token, repo scope

# ── Notifications ────────────────────────────────────────────
MY_PHONE_NUMBER=
MY_EMAIL=
TELEGRAM_CHAT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_SENDER_EMAIL=
TELEGRAM_BOT_TOKEN=

# ── Server ───────────────────────────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:5173
